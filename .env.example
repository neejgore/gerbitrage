# ─────────────────────────────────────────────────────────────────────────────
# Wine Pricing Intelligence API — environment configuration
# Copy to .env and fill in the values you have.
# ─────────────────────────────────────────────────────────────────────────────

# Application
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://gerbitrage:gerbitrage@localhost:5432/gerbitrage

# Redis (used for pricing cache)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────────────────────────────
# Pricing data sources
#
# Set USE_MOCK_PRICING=false once you have at least one real credential.
# The system uses all configured sources and averages the results.
# ─────────────────────────────────────────────────────────────────────────────
USE_MOCK_PRICING=true

# ── Wine-Searcher Pro API ─────────────────────────────────────────────────────
# Best data source. Aggregates 70,000+ merchants globally.
# Plans: $335/mo (500 calls/day) · $535/mo (1,000 calls/day)
# Trial: 100 free calls/day for 5 days
# Sign up: https://www.wine-searcher.com/trade/api
#
WINE_SEARCHER_API_KEY=

# ── CellarTracker ─────────────────────────────────────────────────────────────
# FREE with a free account. Community purchase prices for 3.5M+ wines,
# plus aggregated critic scores (Parker, WS, Decanter, etc.).
# Best free source for fine wine depth.
# Sign up: https://www.cellartracker.com/
#
CELLARTRACKER_USERNAME=
CELLARTRACKER_PASSWORD=

# ── Total Wine (optional session cookie) ──────────────────────────────────────
# Total Wine is the largest US wine retailer. Their site has PerimeterX
# bot protection, but a valid session cookie from a logged-in browser session
# significantly improves scrape success rates.
#
# How to get it:
#   1. Log in to totalwine.com in Chrome
#   2. Open DevTools → Application → Cookies → https://www.totalwine.com
#   3. Copy the FULL cookie string (all cookies joined by "; ")
#   4. Paste below. Refresh every 30 days when the session expires.
#
TOTAL_WINE_SESSION_COOKIE=

# ── Wine.com affiliate API ────────────────────────────────────────────────────
# Requires a Wine.com affiliate/partner account (apply at wine.com).
# Free once approved. Good for mainstream wine retail prices.
#
WINE_COM_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────────────────────────────────────
# How often (hours) to re-price the full catalog. 0 = disable scheduler.
PRICE_REFRESH_INTERVAL_HOURS=24
# Max concurrent wine lookups during a refresh run.
# Scrapers are serialised per-provider regardless of this setting.
PRICE_REFRESH_CONCURRENCY=3
